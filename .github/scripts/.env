ISSUE_BODY=### Platform\n\nLeetCode\n\n### Problem ID\n\n1111\n\n### Problem Title\n\n1 11 1 2\n\n### Language\n\nC++\n\n### Difficulty\n\nEasy\n\n### Tags\n\n_No response_\n\n### Complexity Analysis\n\n- **TC**: O()\n- **SC**: O()\n\n\n### Solution Code\n\nusing vi = vector<int>;\nusing vvi = vector<vi>;\nclass Solution {\npublic:\n    vvi memo;\n    string s, p;\n    bool dp(int i, int j) {\n        if(memo[i][j]!=-1) return memo[i][j];\n\n        bool ans;\n        if (j==p.size()) {\n            ans = (i == s.size());\n        } else {\n            bool first_match = (i < s.size() && (s[i] == p[j] || p[j] == '.'));\n\n            if (j+1<p.size() && p[j+1]=='*') {\n                ans = dp(i, j + 2) || (first_match && dp(i + 1, j));\n            } else {\n                ans = first_match && dp(i + 1, j + 1);\n            }\n        }\n        return memo[i][j] = ans;\n    }\n    bool isMatch(string _s, string _p) {\n        s = _s;\n        p = _p;\n        memo = vvi(s.length()+2, vi(p.length()+2, -1));\n        return dp(0, 0);\n    }\n};
